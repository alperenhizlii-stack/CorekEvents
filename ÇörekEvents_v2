<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="ÇörekEvents">
<meta name="theme-color" content="#0d0d10">
<meta name="description" content="Volkan & Alperen event tracker">
<link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%230d0d10' rx='20'/><text y='70' x='50' font-size='55' text-anchor='middle' fill='%23e9c84a' font-family='serif'>&#199;</text></svg>">
<title>ÇörekEvents</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#0d0d10;--s1:#141418;--s2:#1b1b20;--s3:#232328;--s4:#2a2a30;
  --bd:rgba(255,255,255,0.06);--bd2:rgba(255,255,255,0.11);--bd3:rgba(255,255,255,0.22);
  --tx:#f0ede7;--tx2:#a09c96;--tx3:#5a5752;
  --acc:#e9c84a;--acc2:rgba(233,200,74,0.12);
  --grn:#3ecf7a;--grn2:rgba(62,207,122,0.1);
  --blu:#5b9df5;--blu2:rgba(91,157,245,0.1);
  --pur:#a07ef8;--pur2:rgba(160,126,248,0.1);
  --red:#f07272;--red2:rgba(240,114,114,0.09);
  --ora:#f09050;--ora2:rgba(240,144,80,0.1);
  --pnk:#f07aaa;--pnk2:rgba(240,122,170,0.1);
  --fh:'Syne',sans-serif;--fb:'DM Sans',sans-serif;
}
html,body{background:var(--bg);color:var(--tx);font-family:var(--fb);min-height:100vh;-webkit-font-smoothing:antialiased;}
.wrap{max-width:430px;margin:0 auto;padding-bottom:90px;}
.hdr{background:rgba(13,13,16,0.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);padding:14px 16px 0;border-bottom:0.5px solid var(--bd);position:sticky;top:0;z-index:90;}
.hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.logo{font-family:var(--fh);font-size:20px;font-weight:800;letter-spacing:-0.5px;color:var(--acc);}
.logo span{color:var(--tx);}
.hdr-r{display:flex;align-items:center;gap:8px;}
.cdot{width:8px;height:8px;border-radius:50%;background:var(--tx3);transition:background 0.4s;}
.cdot.ok{background:var(--grn);}.cdot.err{background:var(--red);}
.cdot.spin{background:var(--acc);animation:blink 0.8s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:.2;}50%{opacity:1;}}
.prof-row{display:flex;gap:4px;}
.prof-btn{display:flex;align-items:center;gap:4px;padding:5px 8px;border-radius:20px;font-size:10px;font-weight:700;font-family:var(--fh);cursor:pointer;border:1px solid var(--bd2);background:transparent;color:var(--tx3);transition:all 0.15s;}
.prof-btn.pv.on{background:var(--acc);color:#000;border-color:var(--acc);}
.prof-btn.pa.on{background:var(--pur);color:#fff;border-color:var(--pur);}
.prof-btn.pb.on{background:var(--s3);color:var(--tx);border-color:var(--bd3);}
.av{width:13px;height:13px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:800;}
.av-v{background:var(--acc);color:#000;}.av-a{background:var(--pur);color:#fff;}
.tabs{display:flex;}
.tab{flex:1;padding:10px 4px;font-size:12px;font-weight:700;font-family:var(--fh);color:var(--tx3);cursor:pointer;border:none;background:transparent;border-bottom:2px solid transparent;transition:all 0.2s;}
.tab.on{color:var(--acc);border-bottom-color:var(--acc);}
.pg{display:none;}.pg.on{display:block;}
.kpi-block{margin:14px 16px 0;background:var(--s1);border:0.5px solid var(--bd);border-radius:14px;padding:14px;}
.kpi-lbl{font-family:var(--fh);font-size:9px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:1.3px;margin-bottom:12px;}
.kpi-nums{display:flex;gap:6px;margin-bottom:14px;}
.kn{flex:1;text-align:center;background:var(--s2);border-radius:8px;padding:10px 4px;}
.kn-v{font-family:var(--fh);font-size:20px;font-weight:800;line-height:1;}
.kn-l{font-size:9px;color:var(--tx3);margin-top:3px;}
.rb-wrap{display:flex;flex-direction:column;gap:9px;}
.rb-row{display:flex;flex-direction:column;gap:4px;}
.rb-top{display:flex;justify-content:space-between;align-items:center;}
.rb-name{font-size:11px;font-weight:600;font-family:var(--fh);display:flex;align-items:center;gap:5px;}
.rb-pct{font-family:var(--fh);font-size:12px;font-weight:800;}
.rb-track{height:7px;background:var(--s3);border-radius:4px;overflow:hidden;}
.rb-track.big{height:11px;border-radius:6px;}
.rb-fill{height:100%;border-radius:4px;transition:width 1.2s cubic-bezier(.4,0,.2,1);}
.chip{font-size:8px;font-weight:800;font-family:var(--fh);padding:1px 5px;border-radius:4px;}
.chip-v{background:var(--acc);color:#000;}.chip-a{background:var(--pur);color:#fff;}
.sync-bar{background:rgba(62,207,122,0.04);border:0.5px solid rgba(62,207,122,0.1);border-radius:10px;padding:9px 12px;margin:10px 16px 0;display:flex;align-items:center;gap:8px;}
.sync-txt{flex:1;font-size:10px;color:var(--tx3);}.sync-txt b{font-weight:600;}
.sync-btn{font-size:14px;color:var(--grn);font-weight:800;cursor:pointer;background:transparent;border:none;padding:4px 8px;}
.notice{background:rgba(233,200,74,0.07);border:0.5px solid rgba(233,200,74,0.2);border-radius:10px;padding:10px 13px;margin:10px 16px 0;font-size:10px;color:var(--tx2);line-height:1.6;}
.notice b{color:var(--acc);}.notice a{color:var(--blu);}
.notif-bar{background:rgba(160,126,248,0.07);border:0.5px solid rgba(160,126,248,0.2);border-radius:10px;padding:9px 12px;margin:10px 16px 0;display:flex;align-items:center;gap:8px;cursor:pointer;}
.notif-bar-txt{flex:1;font-size:10px;color:var(--tx3);}
.notif-bar-txt b{color:var(--pur);font-weight:600;}
.notif-bar-btn{font-size:10px;color:var(--pur);font-weight:800;background:transparent;border:none;cursor:pointer;font-family:var(--fh);}
.flt-row{display:flex;gap:5px;padding:12px 16px 10px;overflow-x:auto;scrollbar-width:none;}
.flt-row::-webkit-scrollbar{display:none;}
.fp{padding:5px 12px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;cursor:pointer;border:0.5px solid var(--bd2);background:transparent;color:var(--tx2);font-family:var(--fh);transition:all 0.15s;}
.fp.on{background:var(--acc);color:#000;border-color:var(--acc);}
.ev-list{padding:0 16px;}
.ev{background:var(--s1);border:0.5px solid var(--bd);border-radius:12px;padding:12px 13px;margin-bottom:8px;position:relative;overflow:hidden;}
.ev::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.ev.going::before{background:var(--grn);}.ev.ticket::before{background:var(--blu);}
.ev.maybe::before{background:var(--acc);}.ev.nope{opacity:0.38;}.ev.nope::before{background:var(--s4);}
.ev-hd{display:flex;justify-content:space-between;align-items:flex-start;gap:6px;margin-bottom:5px;}
.ev-nm{font-family:var(--fh);font-size:14px;font-weight:700;line-height:1.2;flex:1;}
.ev-pr{font-family:var(--fh);font-size:12px;font-weight:800;color:var(--acc);white-space:nowrap;}
.ev-mid{display:flex;align-items:center;gap:5px;flex-wrap:wrap;margin-bottom:7px;}
.ev-dt,.ev-vn{font-size:10px;color:var(--tx3);}
.bdg{font-size:9px;font-weight:800;padding:2px 6px;border-radius:4px;font-family:var(--fh);}
.bg{background:var(--grn2);color:var(--grn);}.bt{background:var(--blu2);color:var(--blu);}
.bm{background:var(--acc2);color:var(--acc);}.bn{background:var(--red2);color:var(--red);}
.ev-ft{display:flex;align-items:center;justify-content:space-between;gap:6px;}
.ev-ppl{display:flex;gap:4px;}
.ptg{font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;font-family:var(--fh);}
.pt-v{background:var(--acc2);color:var(--acc);}.pt-a{background:var(--pur2);color:var(--pur);}
.ev-lnk{font-size:9px;color:var(--blu);text-decoration:none;font-weight:700;}
.ev-lnk:hover{text-decoration:underline;}
.ev-notes{font-size:10px;color:var(--tx3);margin-top:6px;padding-top:6px;border-top:0.5px solid var(--bd);line-height:1.5;font-style:italic;}
.next-badge{font-size:8px;font-weight:800;font-family:var(--fh);padding:1px 5px;border-radius:4px;background:rgba(62,207,122,0.15);color:var(--grn);margin-left:5px;vertical-align:middle;}
.cr-badge{display:flex;align-items:center;gap:4px;cursor:pointer;}
.cr-ring{width:30px;height:30px;position:relative;flex-shrink:0;}
.cr-ring svg{width:30px;height:30px;transform:rotate(-90deg);}
.cr-ring-bg{fill:none;stroke:var(--s3);stroke-width:3;}
.cr-ring-fg{fill:none;stroke-width:3;stroke-linecap:round;}
.cr-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:8px;font-weight:800;}
.cr-lbl{font-size:9px;color:var(--tx3);}
.ai-badge{display:inline-flex;align-items:center;gap:3px;font-size:8px;font-weight:700;font-family:var(--fh);padding:1px 5px;border-radius:4px;background:rgba(233,200,74,0.15);color:var(--acc);vertical-align:middle;margin-left:4px;}
.sec-sep{height:0.5px;background:var(--bd);margin:12px 0;}
.sec-ttl{font-family:var(--fh);font-size:9px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:1.3px;padding:0 16px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;}
.szn-pill{font-size:9px;font-weight:800;padding:1px 7px;border-radius:10px;font-family:var(--fh);}
.sp3{background:var(--acc2);color:var(--acc);}
.add-fab{position:fixed;bottom:20px;right:16px;width:52px;height:52px;border-radius:50%;background:var(--acc);color:#000;font-size:26px;font-weight:800;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:80;border:none;box-shadow:0 4px 20px rgba(233,200,74,0.35);transition:transform 0.15s;}
.add-fab:active{transform:scale(0.92);}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:200;align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-sheet{background:var(--s1);border-radius:20px 20px 0 0;padding:20px 16px 36px;width:100%;max-width:430px;border-top:0.5px solid var(--bd2);max-height:92vh;overflow-y:auto;}
.modal-title{font-family:var(--fh);font-size:15px;font-weight:800;margin-bottom:14px;color:var(--acc);}
.form-row{display:flex;flex-direction:column;gap:5px;margin-bottom:11px;}
.form-lbl{font-size:10px;color:var(--tx3);font-weight:700;font-family:var(--fh);}
.form-inp{background:var(--s2);border:0.5px solid var(--bd2);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--tx);font-family:var(--fb);width:100%;outline:none;-webkit-appearance:none;}
.form-inp:focus{border-color:var(--acc);}
.form-inp option{background:var(--s2);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.person-row{display:flex;gap:8px;}
.person-tog{flex:1;padding:9px;border-radius:8px;font-size:11px;font-weight:700;font-family:var(--fh);cursor:pointer;border:0.5px solid var(--bd2);background:transparent;color:var(--tx3);transition:all 0.15s;text-align:center;}
.person-tog.on-v{background:var(--acc2);color:var(--acc);border-color:var(--acc);}
.person-tog.on-a{background:var(--pur2);color:var(--pur);border-color:var(--pur);}
.form-submit{width:100%;padding:12px;background:var(--acc);color:#000;font-size:13px;font-weight:800;font-family:var(--fh);border:none;border-radius:10px;cursor:pointer;margin-top:4px;}
.form-submit:disabled{opacity:0.5;}
.form-cancel{width:100%;padding:10px;background:transparent;color:var(--tx3);font-size:12px;font-family:var(--fh);border:none;cursor:pointer;margin-top:6px;}
.form-msg{font-size:11px;margin-top:8px;padding:8px 10px;border-radius:6px;display:none;}
.form-msg.ok{background:var(--grn2);color:var(--grn);display:block;}
.form-msg.err{background:var(--red2);color:var(--red);display:block;}
.ai-rate-btn{width:100%;padding:10px;background:var(--acc2);color:var(--acc);font-size:11px;font-weight:700;font-family:var(--fh);border:0.5px solid var(--acc);border-radius:8px;cursor:pointer;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:6px;}
.ai-rate-btn:disabled{opacity:0.5;}
.ai-result{background:var(--s2);border-radius:8px;padding:10px 12px;font-size:11px;color:var(--tx2);line-height:1.6;margin-top:8px;display:none;}
.sug-flt{display:flex;gap:5px;padding:10px 16px 8px;overflow-x:auto;scrollbar-width:none;}
.sug-flt::-webkit-scrollbar{display:none;}
.sug-card{background:var(--s1);border:0.5px solid var(--bd);border-radius:12px;padding:13px;margin-bottom:8px;}
.sug-card.ai-gen{border-color:rgba(233,200,74,0.2);}
.sug-hd{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:4px;}
.sug-nm{font-family:var(--fh);font-size:14px;font-weight:700;flex:1;line-height:1.2;}
.sug-mt{font-size:10px;color:var(--tx3);margin-bottom:6px;}
.sug-why{font-size:11px;color:var(--tx2);line-height:1.6;margin-bottom:8px;}
.sug-ft{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;}
.sug-tags{display:flex;gap:4px;flex-wrap:wrap;}
.stag{font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:var(--fh);}
.st-f{background:var(--grn2);color:var(--grn);}.st-c{background:var(--blu2);color:var(--blu);}
.st-n{background:var(--ora2);color:var(--ora);}.st-o{background:var(--acc2);color:var(--acc);}
.st-p{background:var(--pnk2);color:var(--pnk);}.st-t{background:var(--pur2);color:var(--pur);}
.sug-lnk{font-size:9px;color:var(--blu);text-decoration:none;font-weight:700;}
.ai-sug-btn{width:100%;padding:12px;background:var(--s2);border:0.5px solid var(--acc);border-radius:10px;color:var(--acc);font-size:12px;font-weight:700;font-family:var(--fh);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:16px;}
.ai-sug-btn:disabled{opacity:0.5;}
.ai-loading{display:flex;align-items:center;gap:8px;padding:16px;font-size:11px;color:var(--tx3);}
.ai-ld{display:flex;gap:4px;}
.ai-ld span{width:5px;height:5px;border-radius:50%;background:var(--acc);animation:ldp 1.2s ease-in-out infinite;}
.ai-ld span:nth-child(2){animation-delay:.2s;}
.ai-ld span:nth-child(3){animation-delay:.4s;}
@keyframes ldp{0%,100%{opacity:.2;}50%{opacity:1;}}
.city-card{background:var(--s1);border:0.5px solid var(--bd);border-radius:12px;padding:13px;margin-bottom:10px;cursor:pointer;}
.city-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:7px;}
.city-nm{font-family:var(--fh);font-size:17px;font-weight:800;}
.city-sub{font-size:10px;color:var(--tx3);margin-top:1px;}
.city-tags{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;}
.ctg{font-size:10px;padding:2px 8px;border-radius:20px;background:var(--s3);color:var(--tx3);border:0.5px solid var(--bd);}
.city-desc{font-size:11px;color:var(--tx2);line-height:1.6;margin-bottom:8px;}
.city-desc b{color:var(--tx);font-weight:600;}
.city-sep{height:0.5px;background:var(--bd);margin:8px 0;}
.city-nl-ttl{font-size:9px;font-weight:800;font-family:var(--fh);color:var(--pur);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;}
.city-nl-txt{font-size:11px;color:var(--tx3);line-height:1.5;}
.vibs{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px;}
.vib{font-size:9px;padding:2px 8px;border-radius:20px;background:var(--pur2);color:var(--pur);border:0.5px solid rgba(160,126,248,0.15);}
.city-cta{font-size:10px;color:var(--acc);margin-top:8px;font-weight:700;font-family:var(--fh);}
.rm-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:300;align-items:flex-end;justify-content:center;}
.rm-overlay.open{display:flex;}
.rm-sheet{background:var(--s1);border-radius:20px 20px 0 0;padding:20px 16px 40px;width:100%;max-width:430px;border-top:0.5px solid var(--bd2);max-height:85vh;overflow-y:auto;}
.rm-title{font-family:var(--fh);font-size:16px;font-weight:800;margin-bottom:3px;}
.rm-sub{font-size:10px;color:var(--tx3);margin-bottom:14px;display:flex;align-items:center;gap:6px;}
.rm-dims{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}
.rd-row{display:flex;align-items:center;gap:8px;}
.rd-lbl{font-size:10px;font-weight:700;font-family:var(--fh);width:110px;flex-shrink:0;color:var(--tx2);}
.rd-trk{flex:1;height:5px;background:var(--s3);border-radius:3px;overflow:hidden;}
.rd-fill{height:100%;border-radius:3px;transition:width 0.8s ease;}
.rd-v{font-family:var(--fh);font-size:10px;font-weight:800;width:22px;text-align:right;flex-shrink:0;}
.rm-verdict{background:var(--s2);border-radius:8px;padding:10px 12px;font-size:11px;color:var(--tx2);line-height:1.6;margin-bottom:12px;}
.rm-close{width:100%;padding:12px;background:var(--s3);border:none;border-radius:8px;color:var(--tx);font-size:13px;font-weight:700;font-family:var(--fh);cursor:pointer;}
.page-pad{padding:0 16px;}
.empty-state{text-align:center;padding:36px 16px;font-size:12px;color:var(--tx3);line-height:1.8;}
.install-banner{background:var(--s1);border:0.5px solid rgba(233,200,74,0.25);border-radius:12px;padding:12px 14px;margin:12px 16px 0;display:flex;align-items:center;gap:10px;}
.install-icon{font-size:22px;}
.install-txt{flex:1;}
.install-txt div:first-child{font-size:11px;font-weight:700;font-family:var(--fh);color:var(--acc);margin-bottom:2px;}
.install-txt div:last-child{font-size:10px;color:var(--tx3);}
.install-btn{padding:6px 10px;background:var(--acc);color:#000;font-size:10px;font-weight:800;font-family:var(--fh);border:none;border-radius:6px;cursor:pointer;white-space:nowrap;}
</style>
</head>
<body>
<div class="wrap">

<div class="hdr">
  <div class="hdr-top">
    <div class="logo">&#199;&#246;rek<span>Events</span></div>
    <div class="hdr-r">
      <div class="cdot spin" id="cdot"></div>
      <div class="prof-row">
        <button class="prof-btn pv" id="pbv" onclick="setProf('v')"><div class="av av-v">V</div>Volkan</button>
        <button class="prof-btn pa" id="pba" onclick="setProf('a')"><div class="av av-a">A</div>Alperen</button>
        <button class="prof-btn pb on" id="pbb" onclick="setProf('b')">&#304;kisi</button>
      </div>
    </div>
  </div>
  <div class="tabs">
    <button class="tab on" onclick="goTab(0,this)">Tracker</button>
    <button class="tab" onclick="goTab(1,this)">Suggestions</button>
    <button class="tab" onclick="goTab(2,this)">Travel</button>
  </div>
</div>

<!-- TRACKER PAGE -->
<div class="pg on" id="pg0">
  <div class="kpi-block">
    <div class="kpi-lbl" id="kpi-lbl">2026 Realization &#8212; &#199;&#246;rekEvents</div>
    <div class="kpi-nums">
      <div class="kn"><div class="kn-v" style="color:var(--grn)" id="kn-g">&#8212;</div><div class="kn-l">Gidildi</div></div>
      <div class="kn"><div class="kn-v" style="color:var(--blu)" id="kn-t">&#8212;</div><div class="kn-l">Bilet</div></div>
      <div class="kn"><div class="kn-v" style="color:var(--acc)" id="kn-m">&#8212;</div><div class="kn-l">Planland&#305;</div></div>
      <div class="kn"><div class="kn-v" style="color:var(--tx3)" id="kn-n">&#8212;</div><div class="kn-l">Pas</div></div>
