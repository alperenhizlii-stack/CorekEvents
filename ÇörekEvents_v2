      list.innerHTML='<div class="empty-state">AI yaniti parse edilemedi. Statik oneriler yukleniyor...</div>';
      setTimeout(function(){renderSugg(null);},1500);
    }
  })
  .catch(function(){
    btn.disabled=false;btn.textContent='&#10024; AI ile Kisisel Oneriler Al';
    renderSugg(null);
  });
}

/* ── SUGGESTIONS RENDER ── */
function renderSugg(aiList){
  var TL={'st-f':'Festival','st-c':'Konser','st-n':'Nightlife','st-o':'Acikhava','st-p':'Party','st-t':'Niche'};
  var source=aiList||STATIC_SUGG;
  var list=source.filter(function(s){
    var d=pD(s.dateStr);if(!d||d<CUTOFF)return false;
    if(sFlt==='all')return true;
    if(sFlt==='istanbul')return s.geo==='istanbul';
    if(sFlt==='turkey')return s.geo==='turkey'||s.geo==='istanbul';
    if(sFlt==='europe')return s.geo==='europe';
    if(sFlt==='festival')return s.type&&s.type.indexOf('festival')>-1;
    if(sFlt==='concert')return s.type&&s.type.indexOf('concert')>-1;
    return true;
  }).sort(function(a,b){return(pD(a.dateStr)||new Date('2099'))-(pD(b.dateStr)||new Date('2099'));});
  document.getElementById('sug-list').innerHTML=list.map(function(s){
    var sc=crs(s.cr),col=crc(sc);
    var isClose=(pD(s.dateStr)-TODAY)<60*86400000;
    var ri=regR(s.name,s.cr,s.verdict,'CorekRating');
    if(s.aiGen)rmStore[ri].aiRated=true;
    var lkBtn=s.link?'<a class="sug-lnk" href="'+s.link+'" target="_blank">Bilet &rarr;</a>':'';
    return'<div class="sug-card'+(s.aiGen?' ai-gen':'')+'"><div class="sug-hd"><div class="sug-nm">'+s.name+(isClose?'<span class="next-badge">Yakin!</span>':'')+(s.aiGen?'<span class="ai-badge">&#10024; AI</span>':'')+'</div><div class="cr-badge" onclick="openR('+ri+')">'+ring(sc,col)+'</div></div><div class="sug-mt">'+fD(s.dateStr)+' &middot; '+s.venue+'</div><div class="sug-why">'+s.why+'</div><div class="sug-ft"><div class="sug-tags">'+s.tags.map(function(t){return'<span class="stag '+t+'">'+(TL[t]||t)+'</span>';}).join('')+'</div>'+lkBtn+'</div></div>';
  }).join('')||'<div class="empty-state">Bu kategoride yaklasan etkinlik yok.</div>';
}

