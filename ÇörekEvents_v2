  if('Notification' in window&&Notification.permission==='default'){
    document.getElementById('notif-bar').style.display='flex';
  }
}
function requestNotif(){
  if(!('Notification' in window))return;
  Notification.requestPermission().then(function(p){
    document.getElementById('notif-bar').style.display='none';
    if(p==='granted'){scheduleNotifications();showToast('Bildirimler acildi!');}
  });
}
function scheduleNotifications(){
  if(!('Notification' in window)||Notification.permission!=='granted')return;
  var soon=liveEvents.filter(function(e){
    var d=pD(e.dateStr);
    return d&&d>=TODAY&&(d-TODAY)<3*86400000&&e.status!=='nope';
  });
  soon.forEach(function(e){
    var d=pD(e.dateStr);
    var daysLeft=Math.ceil((d-TODAY)/86400000);
    setTimeout(function(){
      try{new Notification('CorekEvents',{body:e.name+' '+daysLeft+' gun sonra! '+fD(e.dateStr),icon:'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect width="100" height="100" fill="%230d0d10" rx="20"/><text y="70" x="50" font-size="55" text-anchor="middle" fill="%23e9c84a">C</text></svg>'});}catch(e){}
    },100);
  });
}
function showToast(msg){
  var t=document.createElement('div');
  t.style.cssText='position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--s2);border:0.5px solid var(--bd2);color:var(--tx);padding:10px 16px;border-radius:8px;font-size:11px;font-family:var(--fh);z-index:500;white-space:nowrap;';
  t.textContent=msg;document.body.appendChild(t);
  setTimeout(function(){t.remove();},3000);
}

/* ── NAV ── */
function setFlt(f,btn){curFlt=f;document.querySelectorAll('.flt-row .fp').forEach(function(b){b.classList.remove('on');});btn.classList.add('on');renderEvs();}
function setSFlt(f,btn){sFlt=f;document.querySelectorAll('.sug-flt .fp').forEach(function(b){b.classList.remove('on');});btn.classList.add('on');renderSugg(aiSugCache);}
function goTab(i,btn){document.querySelectorAll('.tab').forEach(function(b){b.classList.remove('on');});btn.classList.add('on');document.querySelectorAll('.pg').forEach(function(p,j){p.classList.toggle('on',i===j);});}

/* ── INIT ── */
loadSheets();
renderSugg(null);
renderCities();
checkNotifPermission();
</script>
