/* ── EVENT CARD ── */
function stB(s){if(s==='going')return'<span class="bdg bg">Gidildi</span>';if(s==='ticket')return'<span class="bdg bt">Bilet Alindi</span>';if(s==='maybe')return'<span class="bdg bm">Planlandi</span>';return'<span class="bdg bn">Pas</span>';}
function stC(s){return s==='going'?'going':s==='ticket'?'ticket':s==='maybe'?'maybe':'nope';}
function profMatch(e){if(curProf==='v')return e.volkan;if(curProf==='a')return e.alperen;return true;}

function evCard(e){
  var pp=(e.volkan?'<span class="ptg pt-v">V</span>':'')+(e.alperen?'<span class="ptg pt-a">A</span>':'');
  var lk=e.link?'<a class="ev-lnk" href="'+e.link+'" target="_blank">Bilet &rarr;</a>':'';
  var nt=e.notes?'<div class="ev-notes">'+e.notes+'</div>':'';
  var sc=e.score!=null?parseFloat(e.score):null;
  var ringH='';
  if(sc!=null){var ri=regR(e.name,{music:sc,vibe:sc},'Cimcime: '+sc+'/10','Gecmis etkinlik');ringH='<div class="cr-badge" onclick="event.stopPropagation();openR('+ri+')">'+ring(sc,crc(sc))+'<span class="cr-lbl">cimcime</span></div>';}
  var d=pD(e.dateStr);
  var isClose=d&&d>=TODAY&&(d-TODAY)<30*86400000;
  return'<div class="ev '+stC(e.status)+'"><div class="ev-hd"><div class="ev-nm">'+e.name+(isClose?'<span class="next-badge">Yakin!</span>':'')+'</div><div class="ev-pr">'+(e.price?e.price+'&#8378;':'-')+'</div></div><div class="ev-mid"><span class="ev-dt">'+fD(e.dateStr)+'</span>'+(e.venue&&e.venue!=='TBD'?' <span style="color:var(--bd3)">&middot;</span> <span class="ev-vn">'+e.venue+'</span>':'')+' '+stB(e.status)+'</div><div class="ev-ft"><div class="ev-ppl">'+pp+'</div>'+ringH+lk+'</div>'+nt+'</div>';
}

function renderEvs(){
  var evs=liveEvents.filter(function(e){
    var d=pD(e.dateStr);
    if(!d||d<CUTOFF)return false;
    if(!profMatch(e))return false;
    if(curFlt==='upcoming')return e.status!=='nope'&&d>=TODAY;
    if(curFlt==='ticket')return e.status==='ticket';
    if(curFlt==='going')return e.status==='going';
    if(curFlt==='maybe')return e.status==='maybe';
    if(curFlt==='all')return e.status!=='nope';
    return true;
  }).sort(function(a,b){return(pD(a.dateStr)||new Date('2099'))-(pD(b.dateStr)||new Date('2099'));});
  if(!evs.length){document.getElementById('ev-list').innerHTML='<div class="empty-state">Bu filtrede etkinlik yok.</div>';return;}
  var up=evs.filter(function(e){var d=pD(e.dateStr);return d&&d>=TODAY;});
  var pt=evs.filter(function(e){var d=pD(e.dateStr);return !d||d<TODAY;});
  var h='';
  if(up.length){h+='<div class="sec-ttl">Yaklasan <span class="szn-pill sp3">2026</span></div>';up.forEach(function(e){h+=evCard(e);});}
  if(pt.length){if(up.length)h+='<div class="sec-sep" style="margin:12px 0;"></div>';h+='<div class="sec-ttl">Tamamlandi <span class="szn-pill" style="background:var(--bd2);color:var(--tx3);">2026</span></div>';pt.forEach(function(e){h+=evCard(e);});}
  document.getElementById('ev-list').innerHTML=h;
}

/* ── KPI ── */
function calcKPI(){
  var base=liveEvents.filter(function(e){var d=pD(e.dateStr);return d&&d>=CUTOFF&&profMatch(e);});
  var gn=base.filter(function(e){return e.status==='going';});
  var tk=base.filter(function(e){return e.status==='ticket';});
  var my=base.filter(function(e){return e.status==='maybe';});
  var np=base.filter(function(e){return e.status==='nope';});
  var pl=base.filter(function(e){return['going','ticket','maybe'].indexOf(e.status)>-1;});
  document.getElementById('kn-g').textContent=gn.length;document.getElementById('kn-t').textContent=tk.length;document.getElementById('kn-m').textContent=my.length;document.getElementById('kn-n').textContent=np.length;
  var gp=pl.length?Math.round(gn.length/pl.length*100):0;
  var vpl=liveEvents.filter(function(e){var d=pD(e.dateStr);return d&&d>=CUTOFF&&e.volkan&&['going','ticket','maybe'].indexOf(e.status)>-1;});
  var vgn=liveEvents.filter(function(e){var d=pD(e.dateStr);return d&&d>=CUTOFF&&e.volkan&&e.status==='going';});
  var vp=vpl.length?Math.round(vgn.length/vpl.length*100):0;
  var apl=liveEvents.filter(function(e){var d=pD(e.dateStr);return d&&d>=CUTOFF&&e.alperen&&['going','ticket','maybe'].indexOf(e.status)>-1;});
  var agn=liveEvents.filter(function(e){var d=pD(e.dateStr);return d&&d>=CUTOFF&&e.alperen&&e.status==='going';});
  var ap=apl.length?Math.round(agn.length/apl.length*100):0;
  setTimeout(function(){
    document.getElementById('pct-g').textContent=gp+'%';document.getElementById('bar-g').style.width=gp+'%';
    document.getElementById('pct-v').textContent=vp+'%';document.getElementById('bar-v').style.width=vp+'%';
    document.getElementById('pct-a').textContent=ap+'%';document.getElementById('bar-a').style.width=ap+'%';
  },500);
}

/* ── SHEETS LOAD ── */
function parseGviz(data,season,out){
  if(!data||!data.table||!data.table.rows)return;
  data.table.rows.forEach(function(row){
    if(!row.c||!row.c[0]||row.c[0].v==null)return;
    var get=function(i){return row.c&&row.c[i]&&row.c[i].v!=null?row.c[i].v:null;};
    var getF=function(i){return row.c&&row.c[i]&&row.c[i].f!=null?row.c[i].f:null;};
    var name=String(get(0)||'').trim();
    if(!name||name==='Campaign'||name==='Band/Event')return;
    var fmtD=getF(1),rawDate=get(1),dateStr='';
    if(fmtD){var fm=String(fmtD).match(/(\d{1,2})[.\/-](\d{1,2})[.\/-](\d{4})/);if(fm)dateStr=fm[3]+'-'+('0'+fm[2]).slice(-2)+'-'+('0'+fm[1]).slice(-2);else{var fm2=String(fmtD).match(/(\d{4})[.\/-](\d{1,2})[.\/-](\d{1,2})/);if(fm2)dateStr=fm2[1]+'-'+('0'+fm2[2]).slice(-2)+'-'+('0'+fm2[3]).slice(-2);}}
    if(!dateStr&&rawDate){var ds=String(rawDate);var dm=ds.match(/Date\((\d+),(\d+),(\d+)\)/);if(dm){var dd=new Date(+dm[1],+dm[2],+dm[3]);dateStr=dd.getFullYear()+'-'+('0'+(dd.getMonth()+1)).slice(-2)+'-'+('0'+dd.getDate()).slice(-2);}else if(ds.match(/\d{4}-\d{2}-\d{2}/))dateStr=ds.substring(0,10);}
    var d=pD(dateStr);if(season===3&&d&&d<CUTOFF)return;
    var rawSt=String(get(2)||'').trim(),rL=rawSt.toLowerCase();
    var status='maybe';
    if(rL.indexOf('gidildi')>-1||rL.indexOf('gidilir')>-1)status='going';
    else if(rL.indexOf('bilet')>-1)status='ticket';
    else if(rL.indexOf('gidilmez')>-1||rL.indexOf('stop')>-1)status='nope';
    var pm=String(get(3)||'').match(/\d+/);var price=pm?parseInt(pm[0]):null;
    var notes=String(get(4)||'').trim();
    var link='';for(var c=5;c<Math.min(12,(row.c||[]).length);c++){var cv=String(row.c[c]&&row.c[c].v?row.c[c].v:'');if(cv.indexOf('http')===0){link=cv;break;}}
    var venue=String(get(7)||get(6)||'').trim();if(venue.indexOf('http')===0||['Continue','Analyze','Stop'].indexOf(venue)>-1)venue='';
    var score=null;for(var c2=4;c2<Math.min(9,(row.c||[]).length);c2++){var sm=String(row.c[c2]&&row.c[c2].v?row.c[c2].v:'').match(/(\d+)\s*\/\s*10/);if(sm){score=parseInt(sm[1]);break;}}
    var hasV=rL.indexOf('volkan')>-1,hasA=rL.indexOf('alperen')>-1;
    out.push({name:name,dateStr:dateStr,venue:venue||'TBD',status:status,price:price,link:link||null,volkan:hasV||(!hasV&&!hasA),alperen:hasA||(!hasV&&!hasA),score:score,notes:notes||null,season:season});
  });
}

function loadSheets(){
  var dot=document.getElementById('cdot'),txt=document.getElementById('sync-txt');
  dot.className='cdot spin';txt.innerHTML='<b>Baglaniliyor...</b>';
  document.getElementById('sheets-notice').style.display='none';
  var all=[],done=0,sheets=[{gid:'2',season:3}];
  var timer=setTimeout(function(){if(liveEvents.length===0)useFallback('Timeout');},10000);
  sheets.forEach(function(s){
    var cb='gviz_'+s.gid+'_'+Date.now(),sc=document.createElement('script');
    sc.src='https://docs.google.com/spreadsheets/d/'+SHEET_ID+'/gviz/tq?tqx=out:json;responseHandler:'+cb+'&gid='+s.gid;
    window[cb]=function(data){sc.remove();delete window[cb];try{parseGviz(data,s.season,all);}catch(e){}done++;if(done===sheets.length){clearTimeout(timer);onLoaded(all);}};
    sc.onerror=function(){sc.remove();delete window[cb];done++;if(done===sheets.length){clearTimeout(timer);onLoaded(all);}};
    document.head.appendChild(sc);
  });
}

function onLoaded(all){
  if(all.length>0){
    liveEvents=all;
    document.getElementById('cdot').className='cdot ok';
    document.getElementById('sync-txt').innerHTML='<b style="color:var(--grn)">Sheets bagli</b> &middot; '+all.length+' etkinlik &middot; '+new Date().toLocaleTimeString('tr-TR',{hour:'2-digit',minute:'2-digit'});
    scheduleNotifications();
  }else{useFallback('Veri gelmedi');document.getElementById('sheets-notice').style.display='block';}
  renderEvs();calcKPI();
}

function useFallback(r){
  document.getElementById('cdot').className='cdot err';
  document.getElementById('sync-txt').innerHTML='<b style="color:var(--ora)">Sheets baglanamadi</b> &middot; Yerel veri';
  liveEvents=S3_LOCAL;renderEvs();calcKPI();
}

