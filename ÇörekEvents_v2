  var history=liveEvents.filter(function(e){return e.status==='going';}).map(function(e){return e.name+(e.score?' ('+e.score+'/10)':'');}).join(', ');
  var upcoming=liveEvents.filter(function(e){return e.status==='ticket'||e.status==='maybe';}).map(function(e){return e.name;}).join(', ');
