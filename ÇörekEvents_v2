/* ── UTILS ── */
function pD(s){if(!s)return null;var m=String(s).match(/(\d{4})-(\d{1,2})-(\d{1,2})/);if(m)return new Date(+m[1],+m[2]-1,+m[3]);return null;}
function fD(s){var d=pD(s);if(!d)return String(s||'-');return d.toLocaleDateString('tr-TR',{day:'numeric',month:'short',year:'numeric'});}
function crs(cr){var v=Object.values(cr);return Math.round(v.reduce(function(a,b){return a+b;},0)/v.length*10)/10;}
function crc(s){return s>=8?'var(--grn)':s>=6?'var(--acc)':'var(--red)';}
function ring(sc,col){var r=11,c=2*Math.PI*r,o=c-(sc/10)*c;return '<div class="cr-ring"><svg viewBox="0 0 30 30"><circle class="cr-ring-bg" cx="15" cy="15" r="'+r+'"/><circle class="cr-ring-fg" cx="15" cy="15" r="'+r+'" stroke="'+col+'" stroke-dasharray="'+c.toFixed(1)+'" stroke-dashoffset="'+o.toFixed(1)+'"/></svg><div class="cr-num" style="color:'+col+'">'+sc.toFixed(1)+'</div></div>';}

